# Server Configuration
NODE_ENV=development
PORT=5000
API_BASE_URL=http://localhost:5000

# Evaluation Service
EVALUATION_SERVICE_URL=http://4.224.186.213/evaluation-service
CLIENT_ID=your_client_id_here
CLIENT_SECRET=your_client_secret_here

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=24h
JWT_REFRESH_SECRET=your_refresh_secret_key

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/notification_platform
MONGODB_TEST_URI=mongodb://localhost:27017/notification_platform_test

# Redis Configuration
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# RabbitMQ Configuration
RABBITMQ_URL=amqp://localhost:5672
RABBITMQ_QUEUE_NOTIFICATIONS=notifications_queue
RABBITMQ_QUEUE_EMAILS=emails_queue
RABBITMQ_QUEUE_PUSH=push_queue
RABBITMQ_DLQ=dead_letter_queue

# WebSocket Configuration
WS_PORT=5001
WS_HEARTBEAT_INTERVAL=30000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info
LOG_FILE_PATH=./logs
LOG_RETENTION_DAYS=30

# Email Service (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=notifications@platform.com

# Push Notification Service
FCM_SERVER_KEY=your_fcm_server_key
APNS_KEY_ID=your_apns_key_id
APNS_TEAM_ID=your_apns_team_id

# Pagination Defaults
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# Cache TTL (seconds)
CACHE_TTL_NOTIFICATIONS=300
CACHE_TTL_USER=600
CACHE_TTL_STATS=60
